# =============================================================
# TEMPLATE DE CONFIGURAÇÕES (copiar para .env e preencher)
# =============================================================

# --- Base de Dados ---
DB_PATH=/app/base_dados/vagas.db

# --- Email (Resend API) ---
RESEND_API_KEY=re_YOUR_KEY_HERE
EMAIL_DESTINO=teu_email@gmail.com
EMAIL_REMETENTE=vagas@resend.dev

# --- Configurações de Retenção ---
DIAS_RETENCAO=45

# --- Limite de Vagas por Plataforma (por execução) ---
# 0 = ilimitado (produção), >0 = limite por plataforma (teste)
MAX_JOBS_PER_PLATFORM=5

# --- API de Resultados ---
API_KEY=minha-chave-secreta-aqui
